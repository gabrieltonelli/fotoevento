# ============================
# Foto Eventos - Variables de Entorno
# ============================

# --- Supabase ---
# URL de tu proyecto Supabase (se encuentra en Settings > API)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
# Clave anon/pública de Supabase
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Token de acceso personal de Supabase (requerido para MCP o Supabase CLI)
# Obtenelo en: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...

# --- Server ---
# Puerto del servidor backend
PORT=3001
# Clave secreta de Supabase (service_role, solo backend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_URL=https://tu-proyecto.supabase.co

# --- AI Moderation ---
# API Key de OpenAI para moderación de contenido
OPENAI_API_KEY=sk-...

# --- Procesadores de Pago ---
# Procesadores habilitados (separados por coma): stripe,mercadopago
# Ejemplos: "stripe", "mercadopago", "stripe,mercadopago"
PAYMENT_PROCESSORS=stripe,mercadopago
# Procesador por defecto cuando hay varios habilitados: stripe | mercadopago
PAYMENT_DEFAULT_PROCESSOR=mercadopago

# --- Stripe ---
# Clave secreta de Stripe
STRIPE_SECRET_KEY=sk_test_...
# Clave pública de Stripe (para el frontend)
VITE_STRIPE_PUBLIC_KEY=pk_test_...
# Webhook Secret de Stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# --- MercadoPago Argentina ---
# Access Token de MercadoPago (se obtiene en https://www.mercadopago.com.ar/developers)
MP_ACCESS_TOKEN=APP_USR-...
# Public Key de MercadoPago (para el frontend)
VITE_MP_PUBLIC_KEY=APP_USR-...
# Webhook Secret de MercadoPago (para validar notificaciones)
MP_WEBHOOK_SECRET=...

# --- App Config ---
# URL base del frontend
VITE_APP_URL=https://tu-sitio.netlify.app
# URL base del backend
VITE_API_URL=
VITE_MAX_IMAGE_WIDTH=1200
VITE_MAX_IMAGE_HEIGHT=1200
# Máximo de fotos que un invitado puede enviar por vez (default: 3)
VITE_MAX_PHOTOS_PER_UPLOAD=3
# Cantidad de fotos más recientes a rotar en la pantalla en vivo
VITE_SCREEN_ROTATION_LIMIT=4
# Cantidad de fotos por página en el dashboard
VITE_DASHBOARD_PAGE_SIZE=24
PORT=3001
# Procesadores habilitados visibles en el frontend (debe coincidir con PAYMENT_PROCESSORS)
VITE_PAYMENT_PROCESSORS=stripe,mercadopago
# Entorno (development | production)
NODE_ENV=development

# --- Modo Desarrollo (bypass Supabase Auth) ---
# Activar en true para trabajar sin Supabase configurado
# El sistema creará un usuario ficticio con los datos de abajo
# ⚠️ NUNCA activar en producción
VITE_DEV_MODE=false
DEV_MODE=false
# Datos del usuario mock
VITE_DEV_USER_ID=dev-user-00000-00000-00000
VITE_DEV_USER_EMAIL=dev@fotoevento.dev
VITE_DEV_USER_NAME=Dev User
DEV_USER_ID=dev-user-00000-00000-00000
DEV_USER_EMAIL=dev@fotoevento.dev
DEV_USER_NAME=Dev User
