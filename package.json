{
  "name": "fotoevento",
  "version": "1.0.0",
  "description": "Plataforma PWA para compartir fotos en eventos en tiempo real",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=client",
    "start": "npm run start --workspace=server",
    "lint": "npm run lint --workspace=client",
    "preview": "npm run preview --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrieltonelli/fotoevento.git"
  },
  "author": "Gabriel Tonelli",
  "license": "MIT"
}
